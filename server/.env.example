PORT=3000

# Mailjet credentials — get from app.mailjet.com > Account > API Keys
MAILJET_API_KEY=your_api_key_here
MAILJET_API_SECRET=your_api_secret_here

# Default sender (must be a verified Mailjet sender)
FROM_EMAIL=no-reply@yourdomain.com
FROM_NAME=Mail Builder

# Auth0 — API endpoints require a valid Auth0 access token
# AUTH0_DOMAIN is your tenant domain, AUTH0_AUDIENCE must match the API identifier
# configured in the Auth0 dashboard (Applications > APIs)
AUTH0_DOMAIN=YOUR_TENANT.eu.auth0.com
AUTH0_AUDIENCE=https://ng-mail-builder-api

# Angular app origin for CORS (e.g. https://youruser.github.io)
ALLOWED_ORIGIN=http://localhost:4200

# Azure Storage — asset uploads (images) go to this blob container.
# The container is created automatically with public blob read access
# (email clients must be able to fetch the images without auth).
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=assets
