PORT=3000

# Mailjet credentials — get from app.mailjet.com > Account > API Keys
MAILJET_API_KEY=your_api_key_here
MAILJET_API_SECRET=your_api_secret_here

# Default sender (must be a verified Mailjet sender)
FROM_EMAIL=no-reply@yourdomain.com
FROM_NAME=Mail Builder

# Simple API key to protect the /send endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=change_me_to_a_random_secret

# Angular app origin for CORS (e.g. https://youruser.github.io)
ALLOWED_ORIGIN=http://localhost:4200
